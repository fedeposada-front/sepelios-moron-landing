Options -MultiViews
RewriteEngine On
RewriteBase /

# Forzar dominio canónico: https://www.sepeliosmoron.com.ar/
RewriteCond %{HTTP_HOST} !^www\.sepeliosmoron\.com\.ar$ [NC]
RewriteRule ^(.*)$ https://www.sepeliosmoron.com.ar/$1 [R=301,L]

# Forzar HTTPS cuando ya viene con www pero entra por http
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://www.sepeliosmoron.com.ar/$1 [R=301,L]

# SPA fallback: sirve index.html para rutas que no son archivos ni directorios
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule . /index.html [L]